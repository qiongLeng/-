.container{
  display: flex;
  flex-direction: row;
  justify-content: center;
  flex-wrap: wrap;
}
.title_bubble{
  width: 600rpx;
  height: 100rpx;
  background-color: rgb(255, 217, 0);
  border-radius: 40rpx;
  padding: 60rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.bubble_text{
  display: flex;
  flex-direction: column;
}
.text1{
  font-size: 40rpx;
  font-weight: bold;
  text-indent: 30rpx;
  margin: 10rpx;
}
.text2{
  font-size: 40rpx;
  text-indent: 30rpx;
  margin: 10rpx;
}
.bubble_icon{
  width: 120rpx;
  height: 100rpx;
}
.bubble_group_container{
  display: flex;
  flex-direction: row;
  justify-content: center;
  flex-wrap: wrap;
}
.function-bubble{
  width: 300rpx;
  height: 300rpx;
  background-color: rgb(255, 255, 255);
  border-radius: 30rpx;
  box-shadow: 0rpx 0rpx 30rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 25rpx;
}
.temp_icon{
  width: 120rpx;
  height: 120rpx;
  margin: 30rpx;
}
.data-text{
  text-align: right;
}
.data-title{
  font-size: 40rpx;
  color: #7f7f7f;
}
.data-value{
  font-size: 40rpx;
  font-weight: bold;
  color: #7f7f7f;
}
